<Window x:Class="ImageToFontConverter.GlyphsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ImageToFontConverter"
        Title="Glyph List"
        Width="1350"
        Height="820"
        WindowStartupLocation="CenterOwner"
        Background="#0B0D0F">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor"       Color="#1D4ED8"/>
        <SolidColorBrush x:Key="SecondaryColor"     Color="#64748B"/>
        <SolidColorBrush x:Key="DangerColor"        Color="#DC2626"/>
        <SolidColorBrush x:Key="BackgroundColor"    Color="#323C46"/>
        <SolidColorBrush x:Key="BorderColor"        Color="#1E242B"/>
        <SolidColorBrush x:Key="TextColor"          Color="#DDE2E7"/>
        <SolidColorBrush x:Key="TextSecondaryColor" Color="#C2CAD3"/>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"       Value="#1E242B"/>
            <Setter Property="Foreground"       Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="16,8"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="Medium"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2E3842"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Glyph tile -->
        <DataTemplate x:Key="GlyphTile">
            <Border Width="72" Height="80" Margin="3" CornerRadius="6"
                    Background="#1E242B" Cursor="Arrow">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="#2A3340"/>
                    </Style>
                </Border.Style>
                <Border.ToolTip>
                    <ToolTip Background="#1E242B" BorderBrush="#2A3340" BorderThickness="1" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="{Binding ExpectedFileDisplay}" Foreground="#DDE2E7" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="{Binding Description}"         Foreground="#C2CAD3" FontSize="12" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding StatusText}"          Foreground="{Binding ForegroundBrush}" FontSize="12" Margin="0,4,0,0" FontWeight="SemiBold"/>
                        </StackPanel>
                    </ToolTip>
                </Border.ToolTip>
                <Grid>
                    <!-- Found/missing indicator strip at top -->
                    <Border VerticalAlignment="Top" Height="3" CornerRadius="6,6,0,0">
                        <Border.Background>
                            <Binding Path="HasImage">
                                <Binding.Converter>
                                    <local:InverseBooleanToVisibilityConverter/>
                                </Binding.Converter>
                            </Binding>
                        </Border.Background>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasImage}" Value="True">
                                        <Setter Property="Background" Value="#16A34A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasImage}" Value="False">
                                        <Setter Property="Background" Value="#DC2626"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,6,4,4">
                        <!-- Preview area -->
                        <Border Width="40" Height="40" CornerRadius="4" HorizontalAlignment="Center"
                                Background="#2D3640">
                            <Grid>
                                <!-- Show PNG if found -->
                                <Image Source="{Binding Image}" Stretch="Uniform" Margin="3"
                                       Visibility="{Binding HasImage, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <!-- Show unicode char if missing -->
                                <TextBlock Text="{Binding DisplayChar}"
                                           Foreground="#5A6A7A" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVis}}"/>
                            </Grid>
                        </Border>
                        <!-- Filename label -->
                        <TextBlock Text="{Binding ExpectedName}"
                                   Foreground="{Binding ForegroundBrush}"
                                   FontSize="9" TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="68" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <CollectionViewSource x:Key="GroupedGlyphs" Source="{Binding Glyphs}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Category"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- Header bar -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Vertical">
                <TextBlock Text="Expected Glyphs" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextColor}"/>
                <TextBlock Text="{Binding SummaryText}" FontSize="12"
                           Foreground="{StaticResource TextSecondaryColor}" Margin="0,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Close" Width="80"
                    VerticalAlignment="Top" Click="CloseButton_Click"
                    Style="{StaticResource SecondaryButton}"/>
        </Grid>

        <!-- Glyph grid grouped by category -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedGlyphs}}"
                          ItemTemplate="{StaticResource GlyphTile}">
                <ItemsControl.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <StackPanel Margin="0,0,0,16">
                                                <!-- Category header -->
                                                <Border Background="#141A20" CornerRadius="6" Padding="12,7" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Name}"
                                                                   Foreground="#DDE2E7"
                                                                   FontWeight="SemiBold" FontSize="13"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Foreground="#64748B" FontSize="12"
                                                                   VerticalAlignment="Center">
                                                            <Run Text="{Binding ItemCount, Mode=OneWay}"/>
                                                            <Run Text=" glyphs"/>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                                <!-- Tiles wrap -->
                                                <ItemsPresenter/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                        <GroupStyle.Panel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </GroupStyle.Panel>
                    </GroupStyle>
                </ItemsControl.GroupStyle>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>